NEW_API_IMAGE=ghcr.io/johntaoq/new-api
NEW_API_IMAGE_TAG=latest

POSTGRES_USER=root
POSTGRES_PASSWORD=change-me
POSTGRES_DB=new-api

SQL_DSN=postgresql://root:change-me@postgres:5432/new-api
REDIS_CONN_STRING=redis://redis
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
BATCH_UPDATE_ENABLED=true

# Optional: archive image playground outputs to Azure Blob.
IMAGE_PLAYGROUND_BLOB_ENABLED=true
IMAGE_PLAYGROUND_BLOB_CONTAINER=
IMAGE_PLAYGROUND_BLOB_PUBLIC_BASE_URL=
IMAGE_PLAYGROUND_BLOB_MAX_PER_USER=50
AZURE_STORAGE_CONNECTION_STRING=
# Or set these instead of AZURE_STORAGE_CONNECTION_STRING.
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_KEY=
AZURE_STORAGE_CONTAINER=
AZURE_STORAGE_BLOB_ENDPOINT=

# Optional: only needed when the GHCR package is private.
GHCR_USERNAME=
GHCR_TOKEN=
